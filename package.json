{
  "name": "@ankh-studio/copilot-eval-plugin",
  "version": "1.1.0",
  "description": "Production-grade evaluation toolkit for Copilot artifacts with Chain-of-Verification methodology and adversarial rubric testing",
  "main": "plugin.json",
  "files": [
    "plugin.json",
    "agents/",
    "skills/",
    "rubrics/",
    "packs/",
    "scripts/",
    "evals/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ankh-Studio/copilot-eval-plugin.git"
  },
  "keywords": [
    "copilot",
    "evaluation",
    "rubric",
    "assessment",
    "quality",
    "chain-of-verification",
    "adversarial-testing",
    "plugin"
  ],
  "author": "Matthew Van Dusen <matt@ankhstudio.com>",
  "license": "MIT",
  "homepage": "https://github.com/Ankh-Studio/copilot-eval-plugin#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.37.0",
    "yaml-lint": "^1.7.0"
  },
  "scripts": {
    "lint:check": "markdownlint 'README.md' 'CODE_OF_CONDUCT.md' 'CONTRIBUTING.md' 'SECURITY.md' 'SUPPORT.md' '.github/**/*.md' && yamllint '.github/**/*.yml' '.github/**/*.yaml' --config-file .yamllint.yml",
    "lint:fix": "markdownlint 'README.md' 'CODE_OF_CONDUCT.md' 'CONTRIBUTING.md' 'SECURITY.md' 'SUPPORT.md' '.github/**/*.md' --fix"
  }
}
